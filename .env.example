# MkDocs (mkdocs.yml = público, mkdocs.private.yml = completo)
MKDOCS_CONFIG=mkdocs.yml
# Publicación de puertos (host:puerto). Misma IP LAN que el resto de servicios khosting
MKDOCS_PUBLISH=192.168.1.6:8000
MKDOCS_DEV_PUBLISH=192.168.1.6:8001