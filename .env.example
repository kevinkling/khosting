# Cloudflare Tunnel Token
CLOUDFLARE_TOKEN=

# Grafana
GRAFANA_USER=
GRAFANA_PASSWORD=

# MySQL
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=

# PostgreSQL
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# Duplicati
DUPLICATI_ENCRYPTION_KEY=
DUPLICATI_PASSWORD=

# MkDocs (mkdocs.yml = público, mkdocs.private.yml = completo)
MKDOCS_CONFIG=mkdocs.yml
# Publicación de puertos. Default: 8000 en todas las interfaces.
# Para limitar a una IP LAN: MKDOCS_PUBLISH=192.168.1.6:8000
MKDOCS_PUBLISH=8000
MKDOCS_DEV_PUBLISH=8001