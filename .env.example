# Cloudflare Tunnel Token
CLOUDFLARE_TOKEN=

# Grafana
GRAFANA_USER=
GRAFANA_PASSWORD=

# MySQL
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=

# PostgreSQL
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# Duplicati
DUPLICATI_ENCRYPTION_KEY=
